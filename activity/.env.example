# DAS Backend Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# HRM Integration Settings
# ============================================
# HRM Backend URL for employee sync and auto-login code validation  
# This should point to your production HRM backend API
# Examples:
#   Development: http://127.0.0.1:8001
#   Production: https://hrmbackendapi.meridahr.com
# HRM_BASE_URL=https://hrmbackendapi.meridahr.com
HRM_BASE_URL=http://localhost:8001

# ============================================
# CORS Settings (if needed)
# ============================================
# Add your frontend URLs that should be allowed to access the API
ALLOWED_ORIGINS=http://localhost:63105
# ALLOWED_ORIGINS=https://das.meridahr.com
# ============================================
# Database Settings (if using environment variables)
# ============================================
# DATABASE_URL=postgresql://user:password@localhost/dbname
